# 🌐 Puerto del servidor Express (Debe coincidir con VITE_API_URL en el frontend)
PORT=8080

# 🧠 --- INTELIGENCIA ARTIFICIAL (MULTI-PROVIDER) ---
# Selecciona qué proveedor usar: 'openai', 'gemini', 'groq', o 'ollama'
AI_PROVIDER=openai

# 1. OpenAI Config
OPENAI_MODEL=gpt-4o
OPENAI_API_KEY=YOUR_OPENAI_API_KEY_HERE

# 2. Google Gemini Config
GEMINI_MODEL=gemini-1.5-pro
GOOGLE_API_KEY=YOUR_GOOGLE_API_KEY_HERE

# 3. Groq Config (Inferencia ultrarrápida)
GROQ_MODEL=llama3-70b-8192
GROQ_API_KEY=YOUR_GROQ_API_KEY_HERE

# 4. Ollama (Local & 100% Gratis - Descomenta las siguientes líneas para usar)
# AI_PROVIDER=ollama
# OLLAMA_BASE_URL=http://localhost:11434/v1
# OLLAMA_MODEL=llama3.1
# --------------------------------------------------

# 📡 Configuración del Broker MQTT
BROKER=mqtt://localhost:1883
MQTT_USER=your_mqtt_user
MQTT_PASS=your_mqtt_password

# 🏭 Configuración OPC UA
SERVER_IP=192.168.1.100
OPC_ENDPOINT=opc.tcp://:4334/Plc/PlcOpcServer
OPC_HOST=
OPC_PORT=4334
OPC_PATH=/Plc/PlcOpcServer

# 🗄️ Base de Datos (Neon PostgreSQL)
PG_HOST=your-neon-db-host.neon.tech
PG_PORT=5432
PG_USER=your_db_user
PG_PASSWORD=your_db_password
PG_DBNAME=neondb

# 🔒 Configuración TLS/SSL (HTTPS)
SSL_ENABLED=false
TLS_KEY_PATH=./certs/server.key
TLS_CERT_PATH=./certs/server.crt
TLS_CA_PATH=./certs/ca.crt
MQTT_REJECT_UNAUTHORIZED=false
